  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.renderer.json && esbuild src/splash.ts src/renderer/dashboard/orb-scene.ts src/renderer/dashboard/dialog.ts --bundle --outdir=dist --platform=browser --format=iife --target=es2022",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc --watch\" \"tsc -p tsconfig.renderer.json --watch\" \"esbuild src/splash.ts src/renderer/dashboard/orb-scene.ts src/renderer/dashboard/dialog.ts --bundle --outdir=dist --platform=browser --format=iife --target=es2022 --watch\" \"electron .\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
