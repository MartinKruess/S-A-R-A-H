{
  "name": "s-a-r-a-h",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "rebuild:sqlite:node": "npm rebuild better-sqlite3",
    "rebuild:sqlite:electron": "cd node_modules/better-sqlite3 && npx --yes prebuild-install --runtime=electron --target=41.1.1",
    "build:main": "tsc",
    "build:renderer": "esbuild src/splash.ts src/renderer/dashboard/dashboard.ts src/renderer/dashboard/dialog.ts src/renderer/services/audio-worklet-processor.ts --bundle --outdir=dist --platform=browser --format=iife --target=es2022",
    "build:renderer:types": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:renderer:types && npm run build:main && npm run build:renderer",
    "watch:main": "tsc --watch",
    "watch:renderer": "esbuild src/splash.ts src/renderer/dashboard/dashboard.ts src/renderer/dashboard/dialog.ts src/renderer/services/audio-worklet-processor.ts --bundle --outdir=dist --platform=browser --format=iife --target=es2022 --watch",
    "watch:renderer:types": "tsc -p tsconfig.renderer.json --watch",
    "electron": "electron .",
    "predev": "npm run rebuild:sqlite:electron && npm run build",
    "dev": "concurrently -k --kill-signal SIGKILL -n main,types,rnd,app \"npm:watch:main\" \"npm:watch:renderer:types\" \"npm:watch:renderer\" \"npm:electron\"",
    "prestart": "npm run rebuild:sqlite:electron",
    "start": "npm run build && npm run electron",
    "typecheck:main": "tsc --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "test:run": "vitest run",
    "pretest": "npm run rebuild:sqlite:node",
    "test": "npm run typecheck && npm run test:run",
    "posttest": "npm run rebuild:sqlite:electron"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "better-sqlite3": "^12.8.0",
    "systeminformation": "^5.31.5",
    "three": "^0.183.2",
    "uiohook-napi": "^1.5.5",
    "zod": "^4.3.6"
  }
}
