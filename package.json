    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-reloader": "^1.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
